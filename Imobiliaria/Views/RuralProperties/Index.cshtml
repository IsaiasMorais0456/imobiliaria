@model IEnumerable<Model.RuralProperty>

@{
    ViewData["Title"] = "Propriedades Rurais";
    var currentSearch = Context.Request.Query["search"];
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Propriedades Rurais</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Adicionar Nova Propriedade
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form asp-action="Index" method="get">
                <div class="input-group shadow-sm">
                    <input type="text" name="search" class="form-control" placeholder="Buscar pelo título da propriedade..." value="@currentSearch">
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    @if (!string.IsNullOrEmpty(currentSearch))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
                    }
                </div>
            </form>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="alert alert-warning shadow-sm" role="alert">
            Nenhuma propriedade rural encontrada com os critérios de busca atuais.
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/assets/images/properties/default.jpg" : item.ImageUrl)" 
                        class="card-img-top" 
                        alt="@item.Title" 
                        style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title text-primary">@item.Title</h5>
                            <span class="badge bg-secondary">@item.BusinessType.ToString()</span>
                        </div>
                        <h6 class="card-subtitle mb-2 text-muted">@item.Location</h6>
                        <p class="card-text text-truncate" title="@item.Description">@item.Description</p>

                        <ul class="list-group list-group-flush mb-3">
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span><i class="bi bi-tag"></i> Preço:</span>
                                <strong>@item.Price.ToString("C")</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span><i class="bi bi-arrows-fullscreen"></i> Área:</span>
                                <strong>@item.Hectares hectares</strong>
                            </li>
                            <li class="list-group-item px-0">
                                @if (item.HasWaterSource)
                                {
                                    <span class="badge bg-info text-dark">Tem Água</span>
                                }
                                @if (item.HasMainHouse)
                                {
                                    <span class="badge bg-success">Casa Principal</span>
                                }
                            </li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>