@model Model.CommercialProperty

@{
    ViewData["Title"] = "Editar Propriedade";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning">
            <h4 class="mb-0 text-dark">Editar: @Model.Title</h4>
        </div>
        <div class="card-body">
            <form method="post" asp-route-id="@Model.Id" asp-action="Update">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BusinessType" class="form-label">Tipo de Negócio</label>
                        <select asp-for="BusinessType" asp-items="Html.GetEnumSelectList<Model.TypeOfBusiness>()" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label">Preço</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label">Localização</label>
                        <input asp-for="Location" class="form-control" />
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="Description" class="form-label">Descrição</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="RoomSpecification" class="form-label">Especificação de Cômodos</label>
                        <input asp-for="RoomSpecification" class="form-control" />
                    </div>

                    <hr class="my-4" />
                    <h5 class="mb-3 text-secondary">Detalhes Rurais</h5>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Hectares" class="form-label">Tamanho (Hectares)</label>
                        <input asp-for="Hectares" type="number" step="0.01" class="form-control" required />
                    </div>

                    <div class="col-md-4 mb-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="HasWaterSource">
                            <label class="form-check-label" asp-for="HasWaterSource">Possui Fonte de Água?</label>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="HasMainHouse">
                            <label class="form-check-label" asp-for="HasMainHouse">Possui Casa Principal?</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-secondary me-2">Voltar</a>
                    <button type="submit" class="btn btn-warning">Atualizar Propriedade</button>
                </div>
            </form>
        </div>
    </div>
</div>